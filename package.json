{
  "name": "lyrics-on-top",
  "version": "1.0.0",
  "description": "Transparent always-on-top desktop lyrics overlay synced with Spotify",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "npx @electron/packager . \"Lyrics On Top\" --platform=win32 --arch=x64 --out=dist --overwrite",
    "make-installer": "electron-builder --win",
    "dist": "npm run make-installer"
  },
  "build": {
    "appId": "com.lyricsontop.app",
    "productName": "Lyrics On Top",
    "directories": {
      "output": "dist"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lyrics On Top"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    }
  },
  "dependencies": {
    "axios": "^1.6.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "electron-rebuild": "^3.2.9",
    "electron-winstaller": "^5.4.0"
  }
}
